# Credenciais do SQL Server
# Preencha as variáveis abaixo com os dados de acesso ao seu banco de dados Moodle.
# Depois, renomeie este arquivo para .env para que a aplicação possa lê-lo.

DB_USER=NED
DB_PASSWORD=T7mX29eQfLw8
DB_HOST=db.unifenas.br
DB_DATABASE=moodle_db

# Configurações de Criptografia (ajuste conforme a configuração do seu servidor)
# Se o seu SQL Server exige conexões criptografadas (SSL), coloque 'true'. Se não, 'false'.
DB_ENCRYPT=true 
# Se o certificado do seu servidor for autoassinado ou você estiver em um ambiente de desenvolvimento, 
# pode ser necessário usar 'true' para que a conexão seja aceita.
DB_TRUST_SERVER_CERTIFICATE=true
